# =============================================================================
# Cleanup LDIF — removes test scenario data so it can be re-imported
# Run with: ldapmodify -x -D "cn=admin,dc=acmecorp,dc=com" -w <pw> -f acmecorp-test-cleanup.ldif
# Then delete entries with: ldapdelete -x -D "cn=admin,dc=acmecorp,dc=com" -w <pw> -r <dn>
#   for each entry listed in acmecorp-test-cleanup-delete.txt
# =============================================================================

