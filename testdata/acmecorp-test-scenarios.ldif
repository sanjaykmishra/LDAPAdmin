# #############################################################################
# SECTION 2: Access drift — anomalous group memberships
#
# These MODIFY existing groups to add users who don't belong based on
# their department peer group. A Sales person in AWS-Developers, a
# Marketing person in DataAccess-Financial, etc.
#
# All modify operations for the same DN are consolidated into a single
# block to avoid "value already exists" errors.
# #############################################################################

# AWS-Developers: add Sales, HR, and disabled users (all anomalous)
dn: cn=AWS-Developers,ou=Access,ou=Groups,dc=acmecorp,dc=com
changetype: modify
add: member
