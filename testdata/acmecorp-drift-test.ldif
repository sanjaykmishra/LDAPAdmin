# ─── Step 4: Create ANOMALOUS memberships (drift outliers) ───────────────────
# These users have access OUTSIDE their department norm.

# DRIFT OUTLIER 1: Engineering user with Finance access
# Roy Bailey (Engineering) has Payroll-Admin and DataAccess-Financial access
# → Only 1 of 20 (5%) of Engineering peers have this — should flag as HIGH drift
dn: cn=Payroll-Admin,ou=Access,ou=Groups,dc=acmecorp,dc=com
changetype: modify
add: member
member: uid=roy.bailey,ou=Engineering,ou=People,dc=acmecorp,dc=com

# DRIFT OUTLIER 2: Engineering user with HR data access
# Deborah Alvarez (Engineering) has HR-DataAdmin access
# → Only 1 of 20 (5%) — should flag as HIGH drift
dn: cn=HR-DataAdmin,ou=Access,ou=Groups,dc=acmecorp,dc=com
changetype: modify
add: member
member: uid=deborah.alvarez,ou=Engineering,ou=People,dc=acmecorp,dc=com

# DRIFT OUTLIER 3: Engineering user with both Finance AND HR access
# Amy Long (Engineering) has DataAccess-Financial + DataAccess-PII
# → Only 1 of 20 (5%) — should flag as HIGH drift on both groups
dn: cn=DataAccess-PII,ou=Access,ou=Groups,dc=acmecorp,dc=com
changetype: modify
