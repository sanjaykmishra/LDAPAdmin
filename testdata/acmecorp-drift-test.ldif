# =============================================================================
# LDIF Test Data — Access Drift Visualization Scenarios
# Apply with: ldapmodify -c -x -D "cn=admin,dc=acmecorp,dc=com" -w <password> -f testdata/acmecorp-drift-test.ldif
#
# NOTE: Use -c flag to continue on errors (idempotent re-application).
#
# Prerequisites: acmecorp-5000-users.ldif and acmecorp-test-scenarios.ldif
# must already be loaded. The 5000-user data already assigns these users to
# their department-typical groups (GitHub-Users, AWS-Developers, etc.), so
# this LDIF only adds:
#   1. departmentNumber attributes for peer-group analysis
#   2. Anomalous cross-department group memberships (drift outliers)
#
# Expected drift findings after analysis (with anomalyThresholdPct=10):
#   Engineering (20 peers):
#     - Roy Bailey → Payroll-Admin (5%)
#     - Deborah Alvarez → HR-DataAdmin (5%)
#     - Amy Long → DataAccess-PII (5%), DataAccess-Financial (5%)
#   Finance (15 peers):
#     - Howard Blanc → Code-Deploy-Prod (6.7%), AWS-Developers (6.7%)
#     - Heather Fontaine → GitHub-Users (6.7%), BuildSystem-Users (6.7%)
#   Sales (15 peers):
#     - Nancy Watanabe → DataAccess-PII (6.7%), DataAccess-Financial (6.7%)
#     - Stephanie Brown → Code-Deploy-Prod (6.7%)
#   HR (10 peers):
#     - Keith King → Code-Deploy-Prod (10%), AWS-Developers (10%)
#
# Plus any organic anomalies from the original 5000-user data.
# =============================================================================

# ─── Step 1: Add departmentNumber attribute to users ───────────────────────────

# --- Engineering users (20 users) ---
dn: uid=laura.miller,ou=Engineering,ou=People,dc=acmecorp,dc=com
changetype: modify
add: departmentNumber
departmentNumber: Engineering

