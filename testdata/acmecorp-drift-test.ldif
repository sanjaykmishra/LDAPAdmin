# ─── Step 2: Add ANOMALOUS cross-department memberships (drift outliers) ──────
# These create detectable drift by putting users in groups atypical for their
# peer group. Each is a separate modify operation for atomic application.

# OUTLIER 1: Roy Bailey (Engineering) → Payroll-Admin
# 1 of 20 Engineering peers (5%) — HIGH severity
dn: cn=Payroll-Admin,ou=Access,ou=Groups,dc=acmecorp,dc=com
changetype: modify
add: member
member: uid=roy.bailey,ou=Engineering,ou=People,dc=acmecorp,dc=com

# OUTLIER 2: Deborah Alvarez (Engineering) → HR-DataAdmin
# 1 of 20 Engineering peers (5%) — HIGH severity
dn: cn=HR-DataAdmin,ou=Access,ou=Groups,dc=acmecorp,dc=com
changetype: modify
add: member
member: uid=deborah.alvarez,ou=Engineering,ou=People,dc=acmecorp,dc=com

# OUTLIER 3a: Amy Long (Engineering) → DataAccess-PII
# 1 of 20 Engineering peers (5%) — HIGH severity
dn: cn=DataAccess-PII,ou=Access,ou=Groups,dc=acmecorp,dc=com
changetype: modify
add: member
member: uid=amy.long,ou=Engineering,ou=People,dc=acmecorp,dc=com

# OUTLIER 3b: Amy Long (Engineering) → DataAccess-Financial
# 1 of 20 Engineering peers (5%) — HIGH severity
dn: cn=DataAccess-Financial,ou=Access,ou=Groups,dc=acmecorp,dc=com
